# ══════════════════════════════════════════════════
# DC Manager Pro — Environment Config
# 1. Copy:     cp .env.example .env
# 2. Edit:     nano .env
# 3. Deploy:   docker compose up -d --build
# ══════════════════════════════════════════════════

# App access port
APP_PORT=3000

# Database — use simple passwords (avoid @ # % special chars)
DB_USER=dcuser
DB_PASS=changeme123
DB_NAME=dcmanager
DB_EXTERNAL_PORT=5432

# JWT Secret — generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changethis_generate_a_real_secret_here

# Token validity
TOKEN_TTL_HOURS=24

# CORS — set to your domain in production
ALLOWED_ORIGINS=*
