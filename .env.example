# ══════════════════════════════════════════════════
# DC Manager Pro — Environment Config
# 1. Copy:   cp .env.example .env
# 2. Edit:   nano .env   (change passwords!)
# 3. Deploy: docker compose up -d --build
# ══════════════════════════════════════════════════

# App port (browser access)
APP_PORT=3000

# Database
DB_USER=dcuser
DB_PASS=CHANGE_ME_strong_db_password_here
DB_NAME=dcmanager
DB_EXTERNAL_PORT=5432

# JWT — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_real_32char_secret_here
TOKEN_TTL_HOURS=24

# CORS — set to your domain in prod: https://dcmanager.yourcompany.com
ALLOWED_ORIGINS=*
