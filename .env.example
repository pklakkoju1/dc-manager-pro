# ══════════════════════════════════════════════════════════════
# DC Manager Pro — Environment Configuration
#
# Copy this file:   cp .env.example .env
# Edit values:      nano .env
#
# ┌─────────────────────────────────────────────────────────┐
# │  REQUIRED CHANGES before first start                   │
# │  1. DB_PASS      — set a strong database password      │
# │  2. JWT_SECRET   — generate a random 32+ char string   │
# │  3. SERVER_IP    — your server's actual IP address      │
# │  4. NETDATA_STREAM_API_KEY — if using Netdata           │
# └─────────────────────────────────────────────────────────┘
# ══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
# Your server's IP address — used by generate-certs.sh for SSL
SERVER_IP=192.168.86.130

# ── Database ──────────────────────────────────────────────────
# IMPORTANT: Do NOT use @ # % special characters in DB_PASS
DB_USER=dcuser
DB_PASS=changeme123
DB_NAME=dcmanager
DB_EXTERNAL_PORT=5432

# ── Authentication ────────────────────────────────────────────
# Generate a strong secret:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changethis_generate_a_real_secret_here
TOKEN_TTL_HOURS=24

# ── CORS ──────────────────────────────────────────────────────
# Use * for internal tools, or set your domain for production
ALLOWED_ORIGINS=*

# ── Netdata Monitoring ────────────────────────────────────────
# Stream API key — child nodes (bare metal / other VMs) use
# this key to authenticate and stream metrics to this parent.
#
# Generate with:  uuidgen
# Example:        a1b2c3d4-e5f6-7890-abcd-ef1234567890
#
# MUST match the api key used when running install-netdata-child-*.sh
# Change from the default before deploying to production.
#
NETDATA_STREAM_API_KEY=CHANGE-THIS-STREAM-KEY
